# HTML — always revalidate so deploys show up quickly.
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# Versioned assets (?v=<git sha> in HTML) — safe to cache aggressively.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Download manifest — unversioned URL whose content changes per deploy, and
# fetched cross-origin by the auth server's invite landing page.
/assets/download-manifest.json
  Cache-Control: public, max-age=300, must-revalidate
  Access-Control-Allow-Origin: *