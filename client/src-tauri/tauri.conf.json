{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hiroba",
  "version": "0.1.0",
  "identifier": "org.hiroba.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hiroba",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost ws: wss: http: https:"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["hiroba"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCMUQ2RkMzRTIxMDg3QzQKUldURWh4RGl3MjhkZXo3MGtUV1UrNm1BVnVqMFBtYnNEcHFDWTFXSDFIQWhSNWZkYTV3VGhUZjQK",
      "endpoints": [
        "https://github.com/ludo-technologies/hiroba/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
